{
  "name": "electron-react-bootstrap",
  "version": "1.0.0",
  "description": "AQS Inspect",
  "author": "Pulkit Gupta",
  "main": "electron/main.js",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm:dev:react\" \"npm:dev:electron\"",
    "dev:react": "vite",
    "dev:electron": "cross-env NODE_ENV=development wait-on tcp:5173 && electron .",
    "check:syntax": "node ./scripts/check_syntax.js",
    "build:react": "vite build",
    "build": "npm run build:react && electron-builder",
    "build:win": "npm run build:react && electron-builder --win",
    "build:mac": "npm run build:react && electron-builder --mac",
    "build:linux": "npm run build:react && electron-builder --linux"
  },
  "dependencies": {
    "axios": "^1.16.1",
    "mammoth": "^1.12.0",
    "nodemailer": "^6.9.4",
    "officeparser": "^7.2.1",
    "pdf-parse": "^2.4.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@babel/parser": "^7.22.0",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^8.2.0",
    "cross-env": "^7.0.3",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "vite": "^5.0.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.arcwide.aqsinspect",
    "productName": "AQS Inspect",
    "copyright": "Copyright (c) 2026 Pulkit Gupta",
    "asar": true,   
    "files": [
      "electron/**/*",
      "dist/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "assets",
      "output": "release"
    },
    "extraMetadata": {
      "main": "electron/main.js"
    },
    "win": {
      
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    
 "extraResources": [
    {
      "from": "assets",
      "to": "assets"
    }
  ],

    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
